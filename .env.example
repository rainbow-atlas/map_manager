# Supabase (required - get from https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (for create-users script only - NEVER expose in client)
# Get from Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps (optional - for address autocomplete in location form)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Public map base URL — iframe builder default and login “open map” link (optional; same default as in code if unset)
# VITE_QUEER_MAP_EMBED_URL=https://rainbow-atlas.github.io/queer_map/
